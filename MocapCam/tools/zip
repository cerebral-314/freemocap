#!/usr/bin/env python3
import os
import sys
import zipfile
from pathlib import Path


def main() -> int:
    args = sys.argv[1:]
    archive_path = None
    inputs = []
    recursive = False

    index = 0
    while index < len(args):
        arg = args[index]
        if arg == "--":
            index += 1
            break
        if arg.startswith("-") and archive_path is None:
            if "r" in arg:
                recursive = True
            index += 1
            continue
        archive_path = arg
        index += 1
        break

    inputs.extend(args[index:])
    if archive_path is None or not inputs:
        print("usage: zip [-r] archive.zip files...", file=sys.stderr)
        return 1

    archive = Path(archive_path)
    if archive.parent:
        archive.parent.mkdir(parents=True, exist_ok=True)

    with zipfile.ZipFile(archive, "w", compression=zipfile.ZIP_DEFLATED) as output:
        for input_path_string in inputs:
            input_path = Path(input_path_string)
            if input_path.is_dir():
                if not recursive:
                    continue
                for root, _, filenames in os.walk(input_path):
                    for filename in filenames:
                        file_path = Path(root) / filename
                        output.write(file_path, file_path.as_posix())
            elif input_path.exists():
                output.write(input_path, input_path.as_posix())

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
